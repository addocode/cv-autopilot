{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cv-autopilot.dolinsky.ch/schemas/rav-recap-v1.json",
  "title": "RAV Recap",
  "type": "object",
  "required": [
    "schemaVersion",
    "applicationId",
    "applicationDate",
    "applicationMethod",
    "company",
    "job",
    "ravAssignment",
    "workloadCategory",
    "result",
    "instructions",
    "sources"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "applicationId": {"type": "string", "minLength": 1},
    "applicationDate": {"type": "string", "pattern": "^[0-3][0-9]\\.[01][0-9]\\.[0-9]{4}$"},
    "applicationMethod": {"enum": ["Elektronisch", "Brieflich", "Persönlich", "Telefonisch"]},
    "company": {
      "type": "object",
      "required": ["name", "street", "number", "poBox", "country", "postalCode", "city", "contactPerson", "email", "phone"],
      "properties": {
        "name": {"type": "string", "minLength": 1, "maxLength": 100},
        "street": {"type": "string", "minLength": 1},
        "number": {"type": "string", "minLength": 1},
        "poBox": {"type": "string", "minLength": 1},
        "country": {"type": "string", "minLength": 1},
        "postalCode": {"type": "string", "minLength": 1},
        "city": {"type": "string", "minLength": 1},
        "contactPerson": {"type": "string", "minLength": 1, "maxLength": 100},
        "email": {"type": "string", "format": "email", "maxLength": 100},
        "phone": {"type": "string", "minLength": 1, "maxLength": 100}
      },
      "additionalProperties": false
    },
    "job": {
      "type": "object",
      "required": ["title", "applicationUrl", "advertisedWorkload"],
      "properties": {
        "title": {"type": "string", "minLength": 1, "maxLength": 100},
        "applicationUrl": {"type": "string", "format": "uri", "pattern": "^https://"},
        "advertisedWorkload": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "ravAssignment": {"enum": ["Nein", "Ja"]},
    "workloadCategory": {"enum": ["Vollzeit", "Teilzeit"]},
    "result": {"enum": ["Vorstellungsgespräch", "Noch offen", "Anstellung", "Absage"]},
    "instructions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "status", "value", "reason"],
        "properties": {
          "field": {"type": "string", "minLength": 1},
          "status": {"enum": ["job_ad_explicit", "official_research", "reliable_research", "inferred_high_confidence", "fallback_required_field"]},
          "value": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
