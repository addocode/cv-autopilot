{
  "name": "cv-autopilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "validate": "node scripts/validate.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:data": "node --test tests/data.test.mjs",
    "test:render": "node --test tests/render.test.mjs",
    "render": "node scripts/render.mjs",
    "render:all": "node scripts/render-all.mjs",
    "render:motivation-letter": "node scripts/render-motivation-letter.mjs",
    "test:motivation-letter": "node --test tests/motivation-letter.test.mjs",
    "dev": "node scripts/render.mjs -- --variant general",
    "create:application": "node scripts/create-application.mjs",
    "test:application": "node --test tests/application-workflow.test.mjs"
  },
  "dependencies": {
    "@fontsource/roboto-slab": "^5.2.6",
    "@playwright/test": "^1.54.2",
    "ajv": "^8.17.1",
    "pdfjs-dist": "^4.10.38",
    "playwright": "^1.54.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {}
}
